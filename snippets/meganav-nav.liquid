{% liquid
  comment
    Renders the primary meganav content (ie. navigation columns).

    Required parameters:
      - meganav_settings: { Object } The settings object for the associated meganav block.
      - link: { Object } The current menu link.
      - show_collection_images: { Boolean } Whether to show collection images above second-level
        links that are collection links.
      - show_animations: { Boolean } Whether animations are enabled.
  endcomment
-%}

<div
  class="meganav__nav"
  data-column-count="{{ meganav_settings.nav_column_count }}"
  data-show-column-dividers="{{ meganav_settings.show_column_borders }}"
>
  {% liquid
    comment
      Always use the collection's subcollections metafield as the single source of truth.
      This keeps the mega menu and subcollections page in sync.
      Only falls back to nav children if no metafield exists.
    endcomment
    assign use_metafield_subcollections = false
    assign metafield_subcollections = null
    if link.type == 'collection_link' and link.object != blank
      if link.object.metafields.custom.subcollections != blank
        assign use_metafield_subcollections = true
        assign metafield_subcollections = link.object.metafields.custom.subcollections.value
      endif
    endif
  -%}

  <ul class="meganav__list-parent" depth="0" data-show-column-dividers="{{ meganav_settings.show_column_borders }}">
    {% if use_metafield_subcollections -%}
      {%- comment -%} Auto-populated from collection subcollections metafield — compact flex layout {%- endcomment -%}
      {% for subcol in metafield_subcollections -%}
        {% liquid
          assign subcol_image = subcol.featured_image | default: subcol.image
          if meganav_settings.image_source == 'product' and subcol.products.first.featured_media
            assign subcol_image = subcol.products.first.featured_media
          endif
        -%}

        <li class="meganav__list-child meganav__subcol-item animation--dropdown-item" depth="0">
          <a class="meganav__subcol-link" href="{{ subcol.url }}">
            {% if subcol_image -%}
              <span class="meganav__subcol-img">
                <img
                  src="{{ subcol_image | image_url: width: 80 }}"
                  alt="{{ subcol.title | escape }}"
                  loading="lazy"
                  width="40"
                  height="40"
                >
              </span>
            {%- endif %}
            <span class="meganav__subcol-name fs-body-100">{{ subcol.title }}</span>
          </a>
        </li>
      {%- endfor %}

      <style>
        .meganav__list-parent:has(.meganav__subcol-item) {
          display: grid !important;
          grid-template-columns: repeat(var(--nav-column-count), 1fr);
          gap: 8px 24px;
        }
        .meganav__subcol-link {
          display: flex;
          align-items: center;
          gap: 12px;
          text-decoration: none;
          color: inherit;
          padding: 6px 8px;
          border-radius: 8px;
          transition: background 0.15s ease;
        }
        .meganav__subcol-link:hover {
          background: rgba(0, 0, 0, 0.04);
          text-decoration: none !important;
        }
        .meganav__subcol-img {
          width: 40px;
          height: 40px;
          border-radius: 6px;
          overflow: hidden;
          flex-shrink: 0;
          background: #f5f5f5;
        }
        .meganav__subcol-img img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
        .meganav__subcol-name {
          font-weight: 500;
          line-height: 1.3;
        }
        .meganav__subcol-item {
          margin-top: 0 !important;
        }
      </style>
    {%- else -%}
      {%- comment -%} Standard nav children from menu {%- endcomment -%}
      {% for link in link.links -%}
        {% liquid
          assign list_child_class = 'meganav__list-child animation--dropdown-item'

          if link.links.size > 0
            assign list_child_class = list_child_class | append: ' has-children'
          endif
        -%}

        <li class="{{ list_child_class }}" depth="0">
          {% if show_collection_images -%}
            {% liquid
              if link.type == 'collection_link'
                assign collection = link.object
                assign image = collection.image

                if meganav_settings.image_source == 'product'
                  assign image = collection.products.first.featured_media
                endif
              endif
            -%}

            <a class="meganav__list-nav-image-wrap" href="{{ link.url }}" label="{{ link.title }}" tabindex="-1">
              {% render 'image',
                image: image,
                sizes: image_sizes,
                aspect_ratio: meganav_settings.image_aspect_ratio,
                include_placeholder: true,
                animate: show_animations
              -%}
            </a>
          {%- endif %}

          {% liquid
            if link.links and link.links.size > 0
              assign child_title_class = 'has-children fs-accent-bold'
            else
              assign child_title_class = 'fs-body-100'
            endif

            capture child_title
              if link.url == '#'
                echo link.title
              else
                echo link.title | link_to: link.url
              endif
            endcapture
          -%}

          <h4 class="{{ child_title_class }}">
            {{ child_title }}
          </h4>

          {% if link.links and link.links.size > 0 -%}
            <ul depth="1">
              {% for link in link.links -%}
                <li>
                  <a class="fs-body-100" href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor %}
            </ul>
          {%- endif %}
        </li>
      {%- endfor %}
    {%- endif %}
  </ul>

  {% for i in (2..meganav_settings.nav_column_count) -%}
    <span class="meganav__column-rule" data-index="{{ forloop.index }}"></span>
  {%- endfor %}
</div>
