{% comment %}
  Search Bar Snippet with Collection Filter
  Usage: {% render 'search-bar', show_collection_filter: true, placeholder_text: 'Search...', button_style: 'icon_only' %}
{% endcomment %}

{% assign show_filter = show_collection_filter | default: true %}
{% assign placeholder = placeholder_text | default: 'Search...' %}
{% assign btn_style = button_style | default: 'icon_only' %}

<div class="custom-search-bar-wrapper">
  <form class="custom-search-form" id="customSearchForm" action="/search" method="get">
    <input type="hidden" name="type" value="product">

    {% if show_filter %}
      <div class="custom-search-select-wrap">
        <select name="_collection" id="collectionFilter" class="custom-search-select" aria-label="Filter by collection">
          <option value="">All products</option>
          {% for collection in collections %}
            <option value="{{ collection.handle }}">{{ collection.title }}</option>
          {% endfor %}
        </select>
        <span class="custom-search-chevron" aria-hidden="true">
          <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
      </div>
      <div class="custom-search-divider"></div>
    {% endif %}

    <input
      type="text"
      name="q"
      id="searchInput"
      class="custom-search-input"
      placeholder="{{ placeholder }}"
      autocomplete="off"
      aria-label="Search"
    >

    <button type="submit" class="custom-search-btn" aria-label="Submit search">
      <svg class="custom-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="7" stroke="white" stroke-width="2"/>
        <path d="M16.5 16.5L21 21" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </svg>
      {% if btn_style == 'icon_with_text' %}
        <span class="custom-search-btn-text">Search</span>
      {% endif %}
    </button>
  </form>
</div>

<style>
  .custom-search-bar-wrapper {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
  }

  .custom-search-form {
    display: flex;
    align-items: center;
    border: 1.5px solid #d1d5db;
    border-radius: 6px;
    overflow: hidden;
    background: #f5f5f5;
    height: 44px;
  }

  /* --- Dropdown --- */
  .custom-search-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    background: #f5f5f5;
  }

  .custom-search-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    outline: none;
    padding: 0 32px 0 14px;
    height: 44px;
    font-size: 14px;
    color: #222;
    cursor: pointer;
    min-width: 130px;
    font-family: inherit;
  }

  .custom-search-chevron {
    position: absolute;
    right: 10px;
    pointer-events: none;
    color: #555;
    display: flex;
    align-items: center;
  }

  .custom-search-divider {
    width: 1px;
    height: 26px;
    background: #d1d5db;
    flex-shrink: 0;
  }

  /* --- Input --- */
  .custom-search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    padding: 0 14px;
    height: 44px;
    font-size: 14px;
    color: #222;
    font-family: inherit;
    min-width: 0;
  }

  .custom-search-input::placeholder {
    color: #9ca3af;
  }

  /* --- Button --- */
  .custom-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: #1a3c34;
    border: none;
    padding: 0 16px;
    height: 44px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s ease;
    color: white;
  }

  .custom-search-btn:hover {
    background: #14302a;
  }

  .custom-search-btn-text {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .custom-search-select-wrap,
    .custom-search-divider {
      display: none;
    }

    .custom-search-form {
      height: 42px;
    }

    .custom-search-btn {
      padding: 0 14px;
    }
  }
</style>

<script>
  (function () {
    var form = document.getElementById('customSearchForm');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var query = document.getElementById('searchInput').value.trim();
      var collectionSelect = document.getElementById('collectionFilter');
      var collectionHandle = collectionSelect ? collectionSelect.value : '';

      if (!query) return;

      var url;
      if (collectionHandle) {
        // Search within a specific collection
        url = '/collections/' + collectionHandle + '?q=' + encodeURIComponent(query) + '&type=product';
      } else {
        // Search all products
        url = '/search?q=' + encodeURIComponent(query) + '&type=product';
      }

      window.location.href = url;
    });
  })();
</script>