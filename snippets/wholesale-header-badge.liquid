{%- comment -%}Updates the header min order badge when cart changes{%- endcomment -%}
<script>
(function() {
  var MIN_LBS = 5000;
  function updateHeaderBadge() {
    fetch('/cart.js').then(function(r){return r.json()}).then(function(cart) {
      var lbs = (cart.total_weight * 0.00220462).toFixed(1);
      var badge = document.getElementById('header-min-order-badge');
      var lbsEl = document.getElementById('header-cart-lbs');
      if (badge) {
        if (parseFloat(lbs) >= MIN_LBS) {
          badge.style.background = '#d1e7dd';
          badge.style.color = '#0f5132';
        } else {
          badge.style.background = '#fff3cd';
          badge.style.color = '#856404';
        }
      }
      if (lbsEl) lbsEl.textContent = lbs + ' lbs';
    });
  }
  // Listen for cart updates
  document.addEventListener('cart:updated', updateHeaderBadge);
  document.addEventListener('ajaxProduct:added', updateHeaderBadge);
  // Also poll occasionally for cart drawer interactions
  var origFetch = window.fetch;
  window.fetch = function() {
    var result = origFetch.apply(this, arguments);
    if (arguments[0] && typeof arguments[0] === 'string' && (arguments[0].includes('/cart/add') || arguments[0].includes('/cart/change') || arguments[0].includes('/cart/update'))) {
      result.then(function() { setTimeout(updateHeaderBadge, 500); });
    }
    return result;
  };
})();
</script>