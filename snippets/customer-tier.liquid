{% comment %}
  TIERED PRICING LOGIC - FIXED
  Tier 3 > Tier 2 > Tier 1 — priority enforced correctly
  
  Customer Tags: tier1, tier2, tier3
  Metafield Names: Tier 1, Tier 2, Tier 3
  Metafield Keys: tier_1, tier_2, tier_3
  Metafield Type: Price
{% endcomment %}

{% if customer %}
  {%- liquid
    assign customer_price = null
    assign tier_label = ''
    assign has_tier = false

    assign has_tier3 = false
    assign has_tier2 = false
    assign has_tier1 = false

    for tag in customer.tags
      assign tag_lower = tag | downcase | strip
      if tag_lower == 'tier3'
        assign has_tier3 = true
      endif
      if tag_lower == 'tier2'
        assign has_tier2 = true
      endif
      if tag_lower == 'tier1'
        assign has_tier1 = true
      endif
    endfor

    if has_tier3 and product.metafields.custom.tier_3
      assign customer_price = product.metafields.custom.tier_3
      assign tier_label = 'Tier 3'
      assign has_tier = true
    elsif has_tier2 and product.metafields.custom.tier_2
      assign customer_price = product.metafields.custom.tier_2
      assign tier_label = 'Tier 2'
      assign has_tier = true
    elsif has_tier1 and product.metafields.custom.tier_1
      assign customer_price = product.metafields.custom.tier_1
      assign tier_label = 'Tier 1'
      assign has_tier = true
    endif
  -%}

  {% comment %} TIER PRICE — customer has tier tag {% endcomment %}
  {%- if has_tier and customer_price -%}
    <div style="padding: 4px 0;">
      <small style="display:block; font-size:12px; color:gray; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.05em;">
        {{ tier_label }} Price
      </small>
      <span data-price style="font-size:inherit; font-weight:700;">
        {{ customer_price | money }}
      </span>
      <s style="display:block; font-size:14px; color:gray; margin-top:6px;">
        Regular: {{ product.selected_or_first_available_variant.price | money }}
      </s>
    </div>
  {%- else -%}
    {% comment %} NO TIER TAG — Show regular price {% endcomment %}
    <span data-price style="font-size:inherit; font-weight:700;">
      {{ product.selected_or_first_available_variant.price | money }}
    </span>
  {%- endif -%}

{% else %}
  {% comment %} NOT LOGGED IN — Show login link {% endcomment %}
  <a href="/account/login" style="font-size:14px; font-weight:600; color:inherit;">
    Log in to see price
  </a>
{% endif %}
