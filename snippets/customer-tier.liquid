{% comment %}
  TIERED PRICING LOGIC
  Tier 3 > Tier 2 > Tier 1 — priority enforced correctly

  Required parameters:
    - prod: { Object } The associated product object
    - current_variant: { Object } The current variant object
    - show_discount: { Boolean } Whether to show the discount display
    - discount_format: { String } The discount format
{% endcomment %}
{% if customer %}
{%- liquid
  assign customer_price = null
  assign tier_label = ''
  assign has_tier = false

  if customer
    assign has_tier3 = false
    assign has_tier2 = false
    assign has_tier1 = false

    for tag in customer.tags
      assign tag_lower = tag | downcase | strip
      if tag_lower == 'tier3'
        assign has_tier3 = true
      endif
      if tag_lower == 'tier2'
        assign has_tier2 = true
      endif
      if tag_lower == 'tier1'
        assign has_tier1 = true
      endif
    endfor

    if has_tier3 and prod.metafields.custom.tier_3
      assign customer_price = prod.metafields.custom.tier_3.value
      assign tier_label = 'Tier 3'
      assign has_tier = true
    elsif has_tier2 and prod.metafields.custom.tier_2
      assign customer_price = prod.metafields.custom.tier_2.value
      assign tier_label = 'Tier 2'
      assign has_tier = true
    elsif has_tier1 and prod.metafields.custom.tier_1_price
      assign customer_price = prod.metafields.custom.tier_1.value
      assign tier_label = 'Tier 1 '
      assign has_tier = true
    endif
  endif
-%}

{% comment %} NORMAL PRICE — no tier tag {% endcomment %}
{%- unless has_tier -%}
  {% render 'product-price',
    prod: prod,
    current_variant: current_variant,
    show_discount: show_discount,
    discount_format: discount_format
  -%}
{%- endunless -%}

{% comment %} TIER PRICE — customer has tier {% endcomment %}
{%- if has_tier and customer_price -%}
  <div style="padding: 4px 0;">
    <small style="display:block; font-size:12px; color:gray; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.05em;">
      {{ tier_label }} Price
    </small>
    <span data-price style="font-size:inherit; font-weight:700;">
      {{ customer_price | money }}
    </span>
    <s style="display:block; font-size:14px; color:gray; margin-top:6px;">
      Regular: {{ current_variant.price | money }}
    </s>
  </div>
{%- endif -%}
{% else %}
  <a href="/account/login" style="font-size:14px; font-weight:600; color:inherit;">
    Log in to see price
  </a>
{% endif %}
