{% comment %}
  TIERED PRICING — snippets/tier-price.liquid
  
  Flow:
    - Guest           → "Log in to see price"
    - Logged in + tier  → shows tier price from metafield
    - Logged in, no tier → falls through to product-price.liquid
  
  Priority: Tier 3 > Tier 2 > Tier 1
  
  Metafields used:
    custom.tier_1 (Decimal — stores dollar value e.g. 5000.0)
    custom.tier_2 (Decimal — stores dollar value e.g. 4000.0)
    custom.tier_3 (Decimal — stores dollar value e.g. 3000.0)

  Required parameters:
    - prod:            { Object }  The product object
    - current_variant: { Object }  The current variant object
    - show_discount:   { Boolean } Whether to show discount label
    - discount_format: { String }  Discount format string
{% endcomment %}

{%- liquid
  assign customer_price = null
  assign tier_label     = ''
  assign has_tier       = false

  if customer
    assign has_tier1 = false
    assign has_tier2 = false
    assign has_tier3 = false

    for tag in customer.tags
      assign tag_lower = tag | downcase | strip
      if tag_lower == 'tier1'
        assign has_tier1 = true
      endif
      if tag_lower == 'tier2'
        assign has_tier2 = true
      endif
      if tag_lower == 'tier3'
        assign has_tier3 = true
      endif
    endfor

    if has_tier3 and prod.metafields.custom.tier_3.value != blank
      assign customer_price = prod.metafields.custom.tier_3.value
      assign tier_label     = 'Tier 3'
      assign has_tier       = true
    elsif has_tier2 and prod.metafields.custom.tier_2.value != blank
      assign customer_price = prod.metafields.custom.tier_2.value
      assign tier_label     = 'Tier 2'
      assign has_tier       = true
    elsif has_tier1 and prod.metafields.custom.tier_1.value != blank
      assign customer_price = prod.metafields.custom.tier_1.value
      assign tier_label     = 'Tier 1'
      assign has_tier       = true
    endif
  endif
-%}

{% comment %} ── CASE 1: Guest / not logged in ── {% endcomment %}
{% unless customer %}
  <div class="tier-price-wrapper">
    <a href="{{ routes.account_login_url }}"
       style="font-size:14px; font-weight:600; color:inherit; text-decoration:underline;">
      Log in to see price
    </a>
  </div>

{% else %}

  {% comment %} ── CASE 2: Logged in + has tier tag + metafield has value ── {% endcomment %}
  {%- if has_tier and customer_price != blank -%}

    {%- assign tier_price_cents = customer_price | times: 100 | round -%}

    <div class="tier-price-wrapper">
      <small class="tier-price__label">
        {{ tier_label }} Price
      </small>
      <span class="tier-price__amount">
        {{ tier_price_cents | money }}
      </span>
      <s class="tier-price__regular">
        Regular: {{ current_variant.price | money }}
      </s>
    </div>

  {% comment %} ── CASE 3: Logged in but no tier tag — show regular price ── {% endcomment %}
  {%- else -%}

    {% render 'product-price',
      prod: prod,
      current_variant: current_variant,
      show_discount: show_discount,
      discount_format: discount_format
    %}

  {%- endif -%}

{% endunless %}