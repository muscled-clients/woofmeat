{% comment %} Announcement Bar Section {% endcomment %}

{% if request.page_type == 'index' %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400&display=swap" rel="stylesheet">

<style>
  .announcement-bar {
    background-color: {{ section.settings.background_color }};
    width: 100%;
    height: 38px;
    display: flex;
    align-items: center;
    padding: 0 20px;
    box-sizing: border-box;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    letter-spacing: 0%;
    color: {{ section.settings.text_color }};
  }

  .announcement-bar__left {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .announcement-bar__left a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
    white-space: nowrap;
  }

  .announcement-bar__left a:hover {
    opacity: 0.8;
  }

  .announcement-bar__center {
    flex: 1;
    text-align: center;
    white-space: nowrap;
    font-family: 'Figtree', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 18px;
  }

  .announcement-bar__right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    justify-content: flex-end;
  }

  .announcement-bar__social {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .announcement-bar__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    line-height: 1;
  }

  .announcement-bar__social a:hover {
    opacity: 0.8;
  }

  .announcement-bar__social svg {
    width: 16px;
    height: 16px;
    fill: {{ section.settings.text_color }};
  }

  .announcement-bar__divider {
    width: 1px;
    height: 14px;
    background-color: rgba(255,255,255,0.3);
  }

  .announcement-bar__country-flag {
    width: 18px;
    height: 13px;
    border-radius: 2px;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .announcement-bar__country-flag img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Localization Wrapper */
  .announcement-bar__localization {
    position: relative;
    display: flex;
    align-items: center;
  }

  .localization-form {
    display: flex;
    align-items: center;
  }

  /* Trigger Button */
  .localization-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    color: {{ section.settings.text_color }};
    font-family: 'Figtree', sans-serif;
    font-size: 12px;
    font-weight: 400;
    padding: 0;
    white-space: nowrap;
  }

  .localization-trigger:hover {
    opacity: 0.8;
  }

  .localization-trigger__chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .localization-trigger[aria-expanded="true"] .localization-trigger__chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .country-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    list-style: none;
    margin: 0;
    padding: 4px 0;
    min-width: 220px;
    max-height: 300px;
    overflow-y: auto;
    z-index: 999;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }

  .country-dropdown__item {
    margin: 0;
    padding: 0;
  }

  .country-dropdown__option {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 12px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Figtree', sans-serif;
    font-size: 13px;
    font-weight: 400;
    text-align: left;
    color: #333333;
    box-sizing: border-box;
  }

  .country-dropdown__option:hover {
    background-color: #f5f5f5;
  }

  .country-dropdown__option.is-active {
    font-weight: 600;
    color: #000000;
  }
</style>

<div class="announcement-bar" role="banner" aria-label="Announcement bar">

  {%- comment %} LEFT: Nav Links {% endcomment %}
  <nav class="announcement-bar__left" aria-label="Utility navigation">
    {%- for i in (1..5) -%}
      {%- assign label_key = 'nav_label_' | append: i -%}
      {%- assign url_key   = 'nav_url_'   | append: i -%}
      {%- assign label = section.settings[label_key] -%}
      {%- assign url   = section.settings[url_key]   -%}
      {%- if label != blank -%}
        <a href="{{ url | default: '#' }}">{{ label }}</a>
      {%- endif -%}
    {%- endfor -%}
  </nav>

  {%- comment %} CENTER: Announcement Text {% endcomment %}
  <div class="announcement-bar__center">
    {{ section.settings.announcement_text }}
  </div>

  {%- comment %} RIGHT: Social Icons + Localization {% endcomment %}
  <div class="announcement-bar__right">

    <div class="announcement-bar__social">
      {%- if section.settings.facebook_url != blank -%}
        <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.pinterest_url != blank -%}
        <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.641 1.267 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.566 0-2.387-1.715-4.057-4.163-4.057-2.838 0-4.503 2.128-4.503 4.33 0 .857.33 1.776.741 2.278a.3.3 0 0 1 .069.284c-.075.314-.243.995-.276 1.134-.044.183-.146.222-.337.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.967-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.instagram_url != blank -%}
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="{{ section.settings.background_color }}"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="{{ section.settings.background_color }}" stroke-width="2" stroke-linecap="round"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.tiktok_url != blank -%}
        <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="announcement-bar__divider"></div>

    {%- comment %} Shopify Built-in Localization {% endcomment %}
    <div class="announcement-bar__localization">
      {%- if localization.available_countries.size > 1 -%}
        {%- form 'localization', class: 'localization-form' -%}

          <input type="hidden" name="country_code" id="selected_country" value="{{ localization.country.iso_code }}">
          <input type="hidden" name="return_to" value="{{ request.path }}">

          <button type="button" class="localization-trigger" aria-expanded="false" aria-controls="country-dropdown">
            <span class="announcement-bar__country-flag">
              <img
                src="https://cdn.shopify.com/static/images/flags/{{ localization.country.iso_code | downcase }}.svg"
                alt="{{ localization.country.name }}"
                width="18"
                height="13"
                loading="lazy"
              >
            </span>
            <span class="localization-trigger__text">
              {{ localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})
            </span>
            <svg class="localization-trigger__chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <ul class="country-dropdown" id="country-dropdown" hidden>
            {%- for country in localization.available_countries -%}
              <li class="country-dropdown__item">
                <button
                  type="button"
                  class="country-dropdown__option {% if country.iso_code == localization.country.iso_code %}is-active{% endif %}"
                  data-country="{{ country.iso_code }}"
                >
                  <img
                    src="https://cdn.shopify.com/static/images/flags/{{ country.iso_code | downcase }}.svg"
                    alt="{{ country.name }}"
                    width="18"
                    height="13"
                    loading="lazy"
                  >
                  {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </button>
              </li>
            {%- endfor -%}
          </ul>

        {%- endform -%}

      {%- else -%}
        <span class="announcement-bar__country-flag">
          <img
            src="https://cdn.shopify.com/static/images/flags/{{ localization.country.iso_code | downcase }}.svg"
            alt="{{ localization.country.name }}"
            width="18"
            height="13"
          >
        </span>
        <span>{{ localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})</span>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
  (function () {
    const trigger = document.querySelector('.localization-trigger');
    const dropdown = document.getElementById('country-dropdown');

    if (!trigger || !dropdown) return;

    // Open / close dropdown
    trigger.addEventListener('click', function () {
      const isOpen = !dropdown.hidden;
      dropdown.hidden = isOpen;
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });

    // Select a country and submit form
    document.querySelectorAll('.country-dropdown__option').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.getElementById('selected_country').value = btn.dataset.country;
        btn.closest('form').submit();
      });
    });

    // Close when clicking outside
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.announcement-bar__localization')) {
        dropdown.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        dropdown.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    });
  })();
</script>

{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1e3a2f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Announcement Text"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "We stock fair-trade coffee from local brands 🫘"
    },
    {
      "type": "header",
      "content": "Navigation Links"
    },
    {
      "type": "text",
      "id": "nav_label_1",
      "label": "Link 1 label",
      "default": "Shipping"
    },
    {
      "type": "url",
      "id": "nav_url_1",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "nav_label_2",
      "label": "Link 2 label",
      "default": "Returns"
    },
    {
      "type": "url",
      "id": "nav_url_2",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "nav_label_3",
      "label": "Link 3 label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "nav_url_3",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "nav_label_4",
      "label": "Link 4 label",
      "default": "FAQ"
    },
    {
      "type": "url",
      "id": "nav_url_4",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "nav_label_5",
      "label": "Link 5 label",
      "default": "Theme"
    },
    {
      "type": "url",
      "id": "nav_url_5",
      "label": "Link 5 URL"
    },
    {
      "type": "header",
      "content": "Social Media URLs"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
