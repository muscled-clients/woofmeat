{% comment %}
  Section: trending-items.liquid
  Description: Displays a horizontal row of trending product cards pulled
  dynamically from a selected Shopify collection. Shows vendor, title, price,
  and stock status for each product.
{% endcomment %}

<div class="trending-section" id="section-{{ section.id }}">
  <div class="trending-section__inner">

    {% if section.settings.title != blank %}
      <h2 class="trending-section__title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="trending-section__grid">
      {% assign col = collections[section.settings.collection] %}
      {% assign product_limit = section.settings.products_to_show %}

      {% if col != blank %}
        {% for product in col.products limit: product_limit %}
          <a class="trending-card" href="{{ product.url }}">

            <div class="trending-card__image-wrap">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | img_url: '400x400', crop: 'center' }}"
                  alt="{{ product.title | escape }}"
                  class="trending-card__image"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="trending-card__image-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'trending-card__placeholder-svg' }}
                </div>
              {% endif %}
            </div>

            <div class="trending-card__info">
              {% if product.vendor != blank %}
                <span class="trending-card__vendor">{{ product.vendor }}</span>
              {% endif %}

              <p class="trending-card__title">{{ product.title }}</p>

              <p class="trending-card__price">
                {% if product.compare_at_price > product.price %}
                  <span class="trending-card__price--compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
                <span class="trending-card__price--current">{{ product.price | money }}</span>
              </p>

              <span class="trending-card__stock {% if product.available %}trending-card__stock--in{% else %}trending-card__stock--out{% endif %}">
                <span class="trending-card__stock-dot"></span>
                {% if product.available %}In stock{% else %}Out of stock{% endif %}
              </span>
            </div>

          </a>
        {% endfor %}

      {% else %}
        {% comment %} Placeholder cards shown in theme editor when no collection is selected {% endcomment %}
        {% for i in (1..5) %}
          <div class="trending-card trending-card--placeholder">
            <div class="trending-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'trending-card__placeholder-svg' }}
            </div>
            <div class="trending-card__info">
              <span class="trending-card__vendor">Vendor</span>
              <p class="trending-card__title">Product Title</p>
              <p class="trending-card__price"><span class="trending-card__price--current">$00.00</span></p>
              <span class="trending-card__stock trending-card__stock--in">
                <span class="trending-card__stock-dot"></span>In stock
              </span>
            </div>
          </div>
        {% endfor %}
      {% endif %}

    </div>
  </div>
</div>

{% stylesheet %}
.trending-section {
  background: #f3f3f3;
  padding: 32px 20px 40px;
  font-family: inherit;
}

.trending-section__inner {
  max-width: 1200px;
  margin: 0 auto;
}

.trending-section__title {
  font-size: 22px;
  font-weight: 700;
  color: #1a1a1a;
  margin: 0 0 20px;
  text-align: left;
}

/* ── Grid ── */
.trending-section__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0;
  background: #ffffff;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  overflow: hidden;
}

/* ── Card ── */
.trending-card {
  background: #ffffff;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  border-right: 1px solid #e0e0e0;
  transition: background 0.2s ease;
}

.trending-card:last-child {
  border-right: none;
}

.trending-card:hover {
  background: #fafafa;
}

/* ── Image Area ── */
.trending-card__image-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 20px;
  box-sizing: border-box;
}

.trending-card__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.35s ease;
  display: block;
}

.trending-card:hover .trending-card__image {
  transform: scale(1.06);
}

.trending-card__placeholder-svg,
.trending-card__image-placeholder {
  width: 70%;
  height: 70%;
  opacity: 0.25;
}

/* ── Info Area ── */
.trending-card__info {
  padding: 12px 14px 16px;
  border-top: 1px solid #e0e0e0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.trending-card__vendor {
  font-size: 11px;
  color: #888;
  text-transform: capitalize;
  letter-spacing: 0.02em;
}

.trending-card__title {
  font-size: 13px;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.trending-card__price {
  font-size: 13px;
  font-weight: 500;
  color: #1a1a1a;
  margin: 2px 0 0;
  display: flex;
  align-items: center;
  gap: 6px;
}

.trending-card__price--compare {
  color: #999;
  text-decoration: line-through;
  font-weight: 400;
  font-size: 12px;
}

.trending-card__price--current {
  color: #1a1a1a;
}

/* ── Stock Badge ── */
.trending-card__stock {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  margin-top: 4px;
}

.trending-card__stock-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.trending-card__stock--in {
  color: #2e7d32;
}

.trending-card__stock--in .trending-card__stock-dot {
  background: #43a047;
}

.trending-card__stock--out {
  color: #c62828;
}

.trending-card__stock--out .trending-card__stock-dot {
  background: #e53935;
}

/* ── Responsive ── */

/* Large Tablet: 4 columns */
@media (max-width: 1100px) {
  .trending-section__grid {
    grid-template-columns: repeat(4, 1fr);
  }
  /* Reset last-child and add bottom borders for wrapped rows */
  .trending-card:nth-child(4n) {
    border-right: none;
  }
  .trending-card:nth-child(4n+1):nth-last-child(-n+4),
  .trending-card:nth-child(4n+1):nth-last-child(-n+4) ~ .trending-card {
    border-bottom: none;
  }
}

/* Tablet: 3 columns */
@media (max-width: 860px) {
  .trending-section__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .trending-section__title {
    font-size: 20px;
  }

  .trending-card {
    border-right: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
  }

  .trending-card:nth-child(3n) {
    border-right: none;
  }
}

/* Mobile: 2 columns */
@media (max-width: 600px) {
  .trending-section {
    padding: 24px 12px 32px;
  }

  .trending-section__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .trending-section__title {
    font-size: 18px;
    margin-bottom: 14px;
  }

  .trending-card {
    border-right: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
  }

  .trending-card:nth-child(2n) {
    border-right: none;
  }

  .trending-card__image-wrap {
    padding: 12px;
  }

  .trending-card__info {
    padding: 10px 10px 12px;
  }

  .trending-card__title {
    font-size: 12px;
  }

  .trending-card__price {
    font-size: 12px;
  }
}

/* Small Mobile */
@media (max-width: 400px) {
  .trending-section {
    padding: 16px 8px 24px;
  }

  .trending-section__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .trending-section__title {
    font-size: 16px;
  }

  .trending-card__image-wrap {
    padding: 8px;
  }

  .trending-card__info {
    padding: 8px 8px 10px;
    gap: 2px;
  }

  .trending-card__vendor { font-size: 10px; }
  .trending-card__title  { font-size: 11px; }
  .trending-card__price  { font-size: 11px; }
  .trending-card__stock  { font-size: 10px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Trending Items",
  "tag": "section",
  "class": "section-trending-items",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Trending Items"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection to pull trending products from"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products to show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "Trending Items"
    }
  ]
}
{% endschema %}
