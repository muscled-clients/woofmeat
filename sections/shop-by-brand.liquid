{% comment %}
  Section: Shop by Brand
  File: shop-by-brand.liquid
  Compatible with Shopify OS 2.0 themes (Dawn, Refresh, etc.)
{% endcomment %}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign brands_visible = section.settings.brands_visible_before_showmore
  assign total_brands = section.blocks.size
-%}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }};
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  }

  .brand-section-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  .brand-section-title-{{ section.id }} {
    text-align: center;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 24px;
    color: #222222;
    letter-spacing: 0.02em;
  }

  .brand-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ columns_desktop }}, 1fr);
    border-left: 1px solid #e5e5e5;
    border-top: 1px solid #e5e5e5;
  }

  .brand-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px 16px 14px;
    border-right: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    background-color: #f9f9f9;
    text-decoration: none;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
    min-height: 110px;
    cursor: pointer;
  }

  .brand-card-{{ section.id }}:hover {
    background-color: #ffffff;
    box-shadow: inset 0 0 0 2px #dddddd;
    z-index: 1;
  }

  .brand-logo-wrap-{{ section.id }} {
    width: 100%;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }

  .brand-logo-{{ section.id }} {
    max-width: 100%;
    max-height: 70px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .brand-name-{{ section.id }} {
    font-size: 12px;
    color: #666666;
    text-align: center;
    font-weight: 400;
    line-height: 1.3;
    margin-top: 2px;
  }

  .brand-card-hidden-{{ section.id }} {
    display: none;
  }

  .brand-showmore-wrap-{{ section.id }} {
    display: flex;
    justify-content: center;
    margin-top: 28px;
  }

  .brand-showmore-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 32px;
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};
    border: 1.5px solid {{ section.settings.button_text_color }};
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    text-transform: uppercase;
  }

  .brand-showmore-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.button_text_color }};
    color: {{ section.settings.button_background_color }};
  }

  .brand-showmore-btn-{{ section.id }} .btn-arrow {
    display: inline-block;
    transition: transform 0.3s ease;
    font-style: normal;
    font-size: 14px;
  }

  .brand-showmore-btn-{{ section.id }}.expanded .btn-arrow {
    transform: rotate(180deg);
  }

  /* Tablet */
  @media screen and (max-width: 1024px) and (min-width: 769px) {
    .brand-grid-{{ section.id }} {
      grid-template-columns: repeat({% if columns_desktop > 4 %}4{% else %}{{ columns_desktop }}{% endif %}, 1fr);
    }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .brand-grid-{{ section.id }} {
      grid-template-columns: repeat({{ columns_mobile }}, 1fr);
    }

    .brand-card-{{ section.id }} {
      padding: 16px 10px 10px;
      min-height: 90px;
    }

    .brand-logo-wrap-{{ section.id }} {
      height: 50px;
    }

    .brand-logo-{{ section.id }} {
      max-height: 50px;
    }

    .brand-name-{{ section.id }} {
      font-size: 11px;
    }

    .brand-section-title-{{ section.id }} {
      font-size: 17px;
    }
  }
</style>

<section class="brand-section-{{ section.id }}">

  {%- if section.settings.section_title != blank -%}
    <h2 class="brand-section-title-{{ section.id }}">{{ section.settings.section_title }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="brand-grid-{{ section.id }}" id="brand-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign block_index = forloop.index0 -%}
        <a
          class="brand-card-{{ section.id }}{% if block_index >= brands_visible %} brand-card-hidden-{{ section.id }}{% endif %}"
          href="{{ block.settings.brand_link | default: '#' }}"
          data-brand-index="{{ block_index }}"
          {{ block.shopify_attributes }}
        >
          <div class="brand-logo-wrap-{{ section.id }}">
            {%- if block.settings.brand_logo != blank -%}
              {%- assign brand_logo_class = 'brand-logo-' | append: section.id -%}
              {%- assign brand_logo_alt = block.settings.brand_name | escape -%}
              {%- assign brand_logo_url = block.settings.brand_logo | image_url: width: 300 -%}
              <img
                src="{{ brand_logo_url }}"
                alt="{{ brand_logo_alt }}"
                class="{{ brand_logo_class }}"
                loading="lazy"
                width="300"
                height="auto"
              >
            {%- else -%}
              <div style="width:100%;height:60px;background:#e8e8e8;display:flex;align-items:center;justify-content:center;font-size:11px;color:#aaa;">No Image</div>
            {%- endif -%}
          </div>
          {%- if block.settings.brand_name != blank -%}
            <span class="brand-name-{{ section.id }}">{{ block.settings.brand_name }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    {%- if total_brands > brands_visible -%}
      <div class="brand-showmore-wrap-{{ section.id }}">
        <button
          class="brand-showmore-btn-{{ section.id }}"
          id="brand-showmore-btn-{{ section.id }}"
          aria-expanded="false"
          type="button"
        >
          <span class="btn-label">{{ section.settings.show_all_button_text }}</span>
          <i class="btn-arrow">&#8964;</i>
        </button>
      </div>
    {%- endif -%}

  {%- else -%}
    <p style="text-align:center;color:#aaa;font-size:14px;padding:40px 0;">Add brand blocks in the customizer to display them here.</p>
  {%- endif -%}

</section>

<script>
  (function () {
    var sectionId = '{{ section.id }}';
    var brandsVisible = {{ brands_visible }};
    var showAllText = {{ section.settings.show_all_button_text | json }};
    var hideLessText = {{ section.settings.hide_button_text | json }};

    var btn = document.getElementById('brand-showmore-btn-' + sectionId);
    if (!btn) return;

    var hiddenCards = document.querySelectorAll('.brand-card-hidden-' + sectionId);
    var isExpanded = false;

    btn.addEventListener('click', function () {
      isExpanded = !isExpanded;

      hiddenCards.forEach(function (card) {
        if (isExpanded) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });

      btn.querySelector('.btn-label').textContent = isExpanded ? hideLessText : showAllText;
      btn.setAttribute('aria-expanded', isExpanded.toString());

      if (isExpanded) {
        btn.classList.add('expanded');
      } else {
        btn.classList.remove('expanded');
        // Scroll back up to section top smoothly
        var grid = document.getElementById('brand-grid-' + sectionId);
        if (grid) {
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Shop by Brand",
  "tag": "section",
  "class": "shop-by-brand-section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Shop by Brand"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Brands per row (Desktop)",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 6
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Brands per row (Mobile)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "2"
    },
    {
      "type": "number",
      "id": "brands_visible_before_showmore",
      "label": "Brands visible before 'Show All'",
      "default": 12
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Show All Button"
    },
    {
      "type": "text",
      "id": "show_all_button_text",
      "label": "Show All Button Text",
      "default": "SHOW ALL"
    },
    {
      "type": "text",
      "id": "hide_button_text",
      "label": "Show Less Button Text",
      "default": "SHOW LESS"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text / Border Color",
      "default": "#222222"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Collection or Page Link"
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Shop by Brand",
      "blocks": [
        { "type": "brand", "settings": { "brand_name": "Brand 1" } },
        { "type": "brand", "settings": { "brand_name": "Brand 2" } },
        { "type": "brand", "settings": { "brand_name": "Brand 3" } },
        { "type": "brand", "settings": { "brand_name": "Brand 4" } },
        { "type": "brand", "settings": { "brand_name": "Brand 5" } },
        { "type": "brand", "settings": { "brand_name": "Brand 6" } }
      ]
    }
  ]
}
{% endschema %}
