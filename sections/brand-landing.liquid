
{%- assign brand = request.path | split: '/' | last | replace: '-', ' ' -%}
{%- assign brand_param = request.query_string | split: 'brand=' | last | split: '&' | first | url_decode -%}
{%- if brand_param != blank -%}
  {%- assign brand = brand_param -%}
{%- endif -%}

<div class="page__inner" style="max-width:1200px;margin:0 auto;padding:40px 20px;">
  <div style="margin-bottom:24px;">
    <a href="/pages/brands" style="font-size:0.9em;color:#666;text-decoration:none;">← All Brands</a>
  </div>

  <h1 class="ff-heading" style="margin-bottom:8px;text-transform:capitalize;" id="brand-title">{{ brand_param }}</h1>
  <p style="color:#666;margin-bottom:32px;" id="brand-count">Loading products...</p>

  <div id="brand-products" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:24px;">
    <div style="color:#999;">Loading...</div>
  </div>
</div>

<script>
(function() {
  var brand = new URLSearchParams(window.location.search).get('brand') || '';
  if (!brand) { document.getElementById('brand-products').innerHTML = '<p>No brand specified.</p>'; return; }

  document.getElementById('brand-title').textContent = brand;

  // Use Shopify AJAX search with product_type filtering by vendor
  fetch('/search/suggest.json?q=' + encodeURIComponent(brand) + '&resources[type]=product&resources[limit]=250&resources[fields]=title,vendor,handle,image,price')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var products = (data.resources && data.resources.results && data.resources.results.products) || [];
      // Filter strictly by vendor match
      products = products.filter(function(p) {
        return p.vendor && p.vendor.toLowerCase() === brand.toLowerCase();
      });

      document.getElementById('brand-count').textContent = products.length + ' product' + (products.length !== 1 ? 's' : '');

      if (products.length === 0) {
        document.getElementById('brand-products').innerHTML = '<p style="color:#999;">No products found for this brand.</p>';
        return;
      }

      document.getElementById('brand-products').innerHTML = products.map(function(p) {
        var img = p.image ? '<img src="' + p.image + '&width=300" alt="' + p.title.replace(/"/g,'&quot;') + '" style="width:100%;height:180px;object-fit:contain;background:#f9f9f9;border-radius:6px;">' : '<div style="width:100%;height:180px;background:#f5f5f5;border-radius:6px;"></div>';
        return '<a href="' + p.url + '" style="display:block;text-decoration:none;color:#333;border:1px solid #eee;border-radius:8px;overflow:hidden;padding-bottom:12px;">' +
          img +
          '<div style="padding:10px 12px 0;">' +
          '<div style="font-size:0.88em;font-weight:600;margin-bottom:4px;">' + p.title + '</div>' +
          '<div style="font-size:0.85em;color:#666;">Contact for pricing</div>' +
          '</div></a>';
      }).join('');
    })
    .catch(function() {
      document.getElementById('brand-products').innerHTML = '<p style="color:#999;">Error loading products.</p>';
    });
})();
</script>

{% schema %}
{ "name": "Brand Landing", "tag": "section" }
{% endschema %}
