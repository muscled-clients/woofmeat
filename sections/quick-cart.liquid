{% if section.settings.enable_quick_cart -%}
  {% liquid
    assign section_class = 'quick-cart'

    # TODO: Re-enable when we set up quick cart animations.
    comment
      if settings.enable_section_animations
        assign section_class = section_class | append: ' animation animation--quick-cart'
      endif
    endcomment
  -%}

  <div
    class="{{ section_class }}"
    data-section-id="{{ section.id }}"
    data-section-type="quick-cart"
  >
    <div class="quick-cart__wrapper">
      <div class="quick-cart__overlay"></div>

      <div class="quick-cart__container">
        <form
          action="{{ routes.cart_url }}"
          method="post"
          class="quick-cart__form"
          data-form
          novalidate
          data-scroll-lock-ignore
        >
          <div class="quick-cart__header">
            {% liquid
              assign heading_text = 'cart.general.cart' | t

              if cart.item_count > 0
                assign heading_text = heading_text | append: ' ([[cic]])' | replace: '[[cic]]', cart.item_count
              endif
            -%}

            <h2 class="quick-cart__heading ff-heading fs-heading-5-base">{{ heading_text }}</h2>

            <button
              type="button"
              data-modal-close
              class="quick-cart__close-icon"
              aria-label="{{ 'general.accessibility.close_modal' | t }}"
            >
              {% render 'icon-button', icon: 'modal-drawer-close', icon_size: 24 %}
            </button>
          </div>

          {% if cart.item_count > 0 -%}
            <div class="quick-cart__main-content">
              {% render 'free-shipping-bar' %}

              <div class="quick-cart__items animation--container">
                {% liquid
                  for item in cart.items
                    render 'quick-cart-item', parent_id: item.id, item: item, section_settings: section.settings
                  endfor
                -%}
              </div>

              {% liquid
                if settings.enable_cross_sells
                  render 'cross-sells', source: 'quick-cart', cart: cart, is_slider: true
                endif
              -%}
            </div>

            <div class="quick-cart__footer animation--item">
              {% if settings.show_cart_notes -%}
                <div class="quick-cart__footer-order-note-wrapper" aria-expanded="false" aria-hidden="true">
                  <button
                    type="button"
                    class="quick-cart__footer-order-note-trigger fs-body-75 btn btn--text-link"
                    data-order-note-trigger
                  >
                    <div class="quick-cart__footer-order-note-trigger-icons">
                      {% render 'icon', icon: 'plus-small' %}
                      {% render 'icon', icon: 'minus-small', class: 'hidden' %}
                    </div>

                    <span class="quick-cart__footer-order-note-trigger-text" data-cart-not-trigger-text>
                      {{ 'cart.general.order_note_button_add' | t }}
                    </span>
                  </button>

                  <div class="quick-cart__footer-order-note-input" cart-note-input>
                    <label for="CartSpecialInstructions" class="fs-body-100">
                      {{- 'cart.general.order_note_label' | t -}}
                    </label>

                    <textarea
                      name="note"
                      id="CartSpecialInstructions"
                      class="input"
                      placeholder="{{ 'cart.general.order_note_placeholder' | t }}"
                    >
                      {%- liquid
                        if cart.note != blank
                          echo cart.note
                        endif
                      -%}
                    </textarea>
                  </div>
                </div>
              {%- endif %}

              {% if cart.cart_level_discount_applications.size > 0 -%}
                <ul class="quick-cart__item-discounts">
                  {% for discount_application in cart.cart_level_discount_applications -%}
                    <li class="quick-cart__item-discount fs-body-60">
                      {%- render 'icon', icon: 'discount-badge' -%}
                      {{ discount_application.title }} (-{{ discount_application.total_allocated_amount | money }})
                    </li>
                  {%- endfor %}
                </ul>
              {%- endif %}

              <div class="quick-cart__footer-subtotal">
                <h3 class="ff-body fs-body-200">{{ 'cart.general.subtotal' | t }}</h3>

                <span class="ff-product-price fs-body-200">
                  {{- cart.total_price | money -}}
                  {%- if section.settings.show_product_currency %} {{ cart.currency.iso_code }}{%- endif %}
                </span>
              </div>

              {% if customer and customer.tags contains 'approved' %}
                {%- assign cart_total_grams = 0 -%}
                {%- for item in cart.items -%}
                  {%- assign item_total_grams = item.grams | times: item.quantity -%}
                  {%- assign cart_total_grams = cart_total_grams | plus: item_total_grams -%}
                {%- endfor -%}
                {%- assign cart_total_lbs = cart_total_grams | times: 0.00220462 -%}

                <div class="quick-cart__footer-weight" style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding:12px 0;border-top:1px solid rgba(0,0,0,0.08);" data-cart-weight-display>
                  <span class="ff-body fs-body-200" style="font-weight:600;">Total Weight</span>
                  <span class="ff-body fs-body-200" style="font-weight:700;" data-cart-weight-value>
                    {{ cart_total_lbs | round: 1 }} lbs
                  </span>
                </div>
              {% endif %}

              <p class="quick-cart__footer-tax-note ff-body fs-body-75 t-subdued">
                {% liquid
                  if cart.taxes_included and shop.shipping_policy.body != blank
                    echo 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url
                  elsif cart.taxes_included
                    echo 'cart.general.taxes_included_but_shipping_at_checkout' | t
                  elsif shop.shipping_policy.body != blank
                    echo 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url
                  else
                    echo 'cart.general.taxes_and_shipping_at_checkout' | t
                  endif
                -%}
              </p>

              {% if is_wholesale %}
              <button
                type="submit"
                name="checkout"
                id="drawer-checkout-btn"
                class="quick-cart__submit btn btn--full btn--primary"
                aria-label="{{ 'cart.general.checkout' | t }}"
                {% unless cart_total_lbs >= 5000 %}disabled style="opacity:0.5;cursor:not-allowed;"{% endunless %}
              >
                {{ 'cart.general.checkout' | t }}
              </button>
              {% else %}
              <button
                type="submit"
                name="checkout"
                class="quick-cart__submit btn btn--full btn--primary"
                aria-label="{{ 'cart.general.checkout' | t }}"
              >
                {{ 'cart.general.checkout' | t }}
              </button>
              {% endif %}
            </div>
          {%- else -%}
            <div class="quick-cart__empty-state">
              <h3 class="quick-cart__empty-state-heading ff-heading fs-heading fs-heading-4-base">
                {{ 'cart.general.empty' | t }}
              </h3>

              {% if section.settings.collection_list != blank -%}
                {% if section.settings.promotion_text != blank -%}
                  <div class="quick-cart__empty-state-promot-text rte ff-body fs-body-100">
                    {{ section.settings.promotion_text }}
                  </div>
                {%- endif %}

                {% for collection in section.settings.collection_list -%}
                  {% render 'button',
                    label: collection.title,
                    link: collection.url,
                    button_alignment: 'center',
                    button_style: section.settings.collection_list_button_style,
                    wrapper_class: 'quick-cart__empty-state-promo-button'
                  -%}
                {%- endfor %}
              {%- else -%}
                {%- assign empty_label = 'cart.general.continue_shopping' | t -%}

                {% render 'button',
                  label: empty_label,
                  link: routes.collections_url,
                  button_alignment: 'center',
                  button_style: 'secondary',
                  wrapper_class: 'quick-cart__empty-state-promo-button'
                -%}
              {%- endif %}
            </div>
          {%- endif %}
        </form>
      </div>
    </div>
  </div>
{%- endif %}

{% assign is_wholesale = false %}
{% if customer %}
  {% for tag in customer.tags %}
    {% if tag == 'wholesale-approved' %}
      {% assign is_wholesale = true %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if is_wholesale %}
  {%- assign cart_total_grams = 0 -%}
  {%- for item in cart.items -%}
    {%- assign item_grams = item.grams | times: item.quantity -%}
    {%- assign cart_total_grams = cart_total_grams | plus: item_grams -%}
  {%- endfor -%}
  {%- assign cart_total_lbs = cart_total_grams | times: 0.00220462 | round: 1 -%}

  <div id="wholesale-drawer-banner" style="margin:12px 16px 0;padding:12px 14px;border-radius:6px;font-size:0.88em;font-weight:500;
    {% if cart_total_lbs >= 5000 %}background:#d1e7dd;border:1px solid #0f5132;color:#0f5132;
    {% else %}background:#fff3cd;border:1px solid #ffc107;color:#856404;{% endif %}">
    {% if cart_total_lbs >= 5000 %}
      &#10003; Minimum order met &mdash; <strong>{{ cart_total_lbs }} lbs</strong> in cart.
    {% else %}
      &#9888; Min order is 5,000 lbs. You have <strong id="drawer-lbs">{{ cart_total_lbs }} lbs</strong>.
    {% endif %}
  </div>
{% endif %}


{% if is_wholesale %}
<script>
(function() {
  var MIN_LBS = 5000;

  function updateDrawer() {
    fetch('/cart.js', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var totalGrams = 0;
        (cart.items || []).forEach(function(i) { totalGrams += (i.grams || 0) * (i.quantity || 0); });
        var lbs = totalGrams * 0.00220462;
        var lbsRounded = lbs.toFixed(1);

        var banner = document.getElementById('wholesale-drawer-banner');
        var btn = document.getElementById('drawer-checkout-btn');
        var lbsEl = document.getElementById('drawer-lbs');

        if (lbsEl) lbsEl.textContent = lbsRounded + ' lbs';

        if (banner) {
          if (lbs >= MIN_LBS) {
            banner.style.background = '#d1e7dd';
            banner.style.border = '1px solid #0f5132';
            banner.style.color = '#0f5132';
            banner.innerHTML = '&#10003; Minimum order met &mdash; <strong>' + lbsRounded + ' lbs</strong> in cart.';
          } else {
            banner.style.background = '#fff3cd';
            banner.style.border = '1px solid #ffc107';
            banner.style.color = '#856404';
            banner.innerHTML = '&#9888; Min order is 5,000 lbs. You have <strong>' + lbsRounded + ' lbs</strong>.';
          }
        }

        if (btn) {
          btn.disabled = lbs < MIN_LBS;
          btn.style.opacity = lbs < MIN_LBS ? '0.5' : '';
          btn.style.cursor = lbs < MIN_LBS ? 'not-allowed' : '';
        }
      });
  }

  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-add-quantity],[data-subtract-quantity],[data-remove-item]')) {
      setTimeout(updateDrawer, 700);
      setTimeout(updateDrawer, 1400);
    }
  });

  document.addEventListener('change', function(e) {
    if (e.target && e.target.matches('[name="quantity"]')) {
      setTimeout(updateDrawer, 700);
    }
  });

  var drawer = document.querySelector('.quick-cart');
  if (drawer) {
    new MutationObserver(function() { setTimeout(updateDrawer, 400); })
      .observe(drawer, { childList: true, subtree: true });
  }
})();
</script>
{% endif %}

{% schema %}
{
  "name": "t:sections.quick_cart.name",
  "settings": [
    {
      "id": "enable_quick_cart",
      "type": "checkbox",
      "label": "t:sections.quick_cart.settings.enable_quick_cart.label",
      "info": "t:sections.quick_cart.settings.enable_quick_cart.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.quick_cart.settings.header__product.content"
    },
    {
      "id": "show_product_currency",
      "type": "checkbox",
      "label": "t:sections.quick_cart.settings.show_product_currency.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.quick_cart.settings.header__promotion.content"
    },
    {
      "type": "richtext",
      "id": "promotion_text",
      "label": "t:sections.quick_cart.settings.promotion_text.label",
      "default": "<p>Check out these collections.</p>"
    },
    {
      "id": "collection_list",
      "type": "collection_list",
      "label": "t:sections.quick_cart.settings.collection_list.label"
    },
    {
      "type": "select",
      "id": "collection_list_button_style",
      "label": "t:sections.quick_cart.settings.collection_list_button_style.label",
      "default": "outline",
      "options": [
        {
          "value": "primary",
          "label": "t:shared.settings.button_style.option_solid"
        },
        {
          "value": "outline",
          "label": "t:shared.settings.button_style.option_outline"
        }
      ]
    }
  ]
}
{% endschema %}
