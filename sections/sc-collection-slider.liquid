<section class="sc-collection-slider">
  {% if section.settings.heading != blank %}
    <h2 class="sc-heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="sc-slider" id="sc-slider-{{ section.id }}">
    {% for block in section.blocks %}
      {% assign c = block.settings.collection %}
      {% if c != blank %}
        <a class="sc-item" href="{{ c.url }}" {{ block.shopify_attributes }}>
          <div class="sc-img">
            {% if block.settings.custom_image != blank %}
              <img src="{{ block.settings.custom_image | image_url: width: 500 }}" alt="{{ c.title | escape }}" loading="lazy">
            {% elsif c.featured_image != blank %}
              <img src="{{ c.featured_image | image_url: width: 500 }}" alt="{{ c.title | escape }}" loading="lazy">
            {% endif %}
          </div>
          <div class="sc-title">{{ c.title }}</div>
        </a>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.arrows %}
    <div class="sc-arrows">
      <button class="sc-btn" type="button" data-dir="-1">‹</button>
      <button class="sc-btn" type="button" data-dir="1">›</button>
    </div>
  {% endif %}
</section>

<style>
  .sc-collection-slider{padding:40px 0;text-align:center}
  .sc-heading{font-size:32px;font-weight:700;margin:0 0 26px}
  .sc-slider{
    position: relative;
    display:flex;gap:46px;align-items:flex-start;overflow-x:hidden;padding:10px 22px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}
  .sc-item{flex:0 0 auto;width:220px;text-decoration:none;color:inherit;scroll-snap-align:center}
  .sc-img{width:200px;height:200px;margin:0 auto 14px;border-radius:999px;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#fff}
  .sc-img img{width:100%;height:100%;object-fit:contain}
  .sc-title{
    
    font-size:15px;font-weight:500}
  .sc-arrows{display:flex;gap:10px;justify-content:space-between;
    position: absolute;
    width: 100%;
    margin-top: -10%;
  }
  .sc-btn{width:44px;height:44px;border:1px solid #ddd;border-radius:999px;background:#fff;cursor:pointer}
  .sc-btn:hover{
    border:1px solid #1f4a37;
    background:#1f4a37;
    color:white;
  }
</style>

<script>
  (function(){
    var root = document.getElementById('sc-slider-{{ section.id }}');
    if(!root) return;
    var wrap = root.closest('.sc-collection-slider');
    if(!wrap) return;
    wrap.querySelectorAll('.sc-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var dir = parseInt(btn.getAttribute('data-dir'),10);
        root.scrollBy({ left: dir * 320, behavior: 'smooth' });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "SC - Collections Slider",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Discover the best bites and beverages to stay on trend in 2026." },
    { "type": "checkbox", "id": "arrows", "label": "Show arrows", "default": true }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Select collection" },
        { "type": "image_picker", "id": "custom_image", "label": "Custom icon (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "SC-Collections Slider" }]
}
{% endschema %}
